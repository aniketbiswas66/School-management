@model List<NalandaSchool.Models.DiaryEntry>
@{ ViewBag.Title = "Daily Diary"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<h1>Daily Diary</h1>
<p class="sub">Add and view daily lesson entries</p>

@using (Html.BeginForm("AddDiary", "Teacher", FormMethod.Post))
{
    <div class="card">
        <b>New Entry</b><br><br>
        <div class="form-row">
            <div class="form-group">
                <label>Date</label>
                <input type="date" name="Date" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
            </div>
            <div class="form-group">
                <label>Class</label>
                <select name="Class">
                    <option>10-A</option><option>10-B</option><option>9-A</option>
                </select>
            </div>
        </div>
        <div class="form-row">
            <div class="form-group">
                <label>Subject</label>
                <select name="Subject">
                    <option>Mathematics</option><option>Science</option>
                    <option>English</option><option>History</option><option>Computer Science</option>
                </select>
            </div>
            <div class="form-group">
                <label>Topic Covered</label>
                <input type="text" name="Topic" placeholder="Chapter / topic name" />
            </div>
        </div>
        <div class="form-group">
            <label>Homework</label>
            <input type="text" name="Homework" placeholder="Exercise / page number" />
        </div>
        <button type="submit" class="btn btn-blue">Save Entry</button>
    </div>
}

<h2 style="font-size:16px;margin-bottom:12px">Previous Entries</h2>
<table>
    <thead>
        <tr><th>Date</th><th>Class</th><th>Subject</th><th>Topic</th><th>Homework</th><th>Teacher</th></tr>
    </thead>
    <tbody>
        @foreach (var d in Model)
        {
            <tr>
                <td>@d.Date</td>
                <td>@d.Class</td>
                <td>@d.Subject</td>
                <td>@d.Topic</td>
                <td>@d.Homework</td>
                <td>@d.TeacherName</td>
            </tr>
        }
    </tbody>
</table>
