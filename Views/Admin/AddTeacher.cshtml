@{ ViewBag.Title = "Add Teacher"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<h1>Add Teacher</h1>
<p class="sub">Register a new faculty member</p>

@using (Html.BeginForm("AddTeacher", "Admin", FormMethod.Post))
{
    <div class="card">
        <div class="form-row">
            <div class="form-group">
                <label>Full Name</label>
                <input type="text" name="Name" required />
            </div>
            <div class="form-group">
                <label>Department</label>
                <select name="Department">
                    <option>Mathematics</option><option>Science</option>
                    <option>English</option><option>History</option>
                    <option>Computer Science</option>
                </select>
            </div>
        </div>
        <div class="form-row">
            <div class="form-group">
                <label>Phone</label>
                <input type="text" name="Phone" />
            </div>
            <div class="form-group">
                <label>Email</label>
                <input type="email" name="Email" />
            </div>
        </div>
        <button type="submit" class="btn btn-blue">Save Teacher</button>
        &nbsp;<a class="btn btn-red" href="@Url.Action("Teachers")">Cancel</a>
    </div>
}
