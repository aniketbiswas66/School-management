@{ ViewBag.Title = "Add Student"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<h1>Add Student</h1>
<p class="sub">Register a new student</p>

@using (Html.BeginForm("AddStudent", "Admin", FormMethod.Post))
{
    <div class="card">
        <div class="form-row">
            <div class="form-group">
                <label>Full Name</label>
                <input type="text" name="Name" required />
            </div>
            <div class="form-group">
                <label>Class</label>
                <select name="Class">
                    <option>9-A</option><option>9-B</option>
                    <option>10-A</option><option>10-B</option>
                    <option>11-A</option><option>11-B</option>
                </select>
            </div>
        </div>
        <div class="form-row">
            <div class="form-group">
                <label>Phone</label>
                <input type="text" name="Phone" />
            </div>
            <div class="form-group">
                <label>Email</label>
                <input type="email" name="Email" />
            </div>
        </div>
        <button type="submit" class="btn btn-blue">Save Student</button>
        &nbsp;<a class="btn btn-red" href="@Url.Action("Students")">Cancel</a>
    </div>
}
