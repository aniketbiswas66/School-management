<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Nalanda Institute — @ViewBag.Title</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: Arial, sans-serif; font-size: 14px; color: #222; background: #f4f4f4; }

        /* NAV */
        nav { background: #1a3a5c; color: #fff; padding: 0 20px; display: flex; align-items: center; height: 50px; gap: 20px; }
        nav a { color: #cce; text-decoration: none; }
        nav a:hover { color: #fff; }
        nav .brand { font-size: 16px; font-weight: bold; color: #fff; flex: 1; }
        nav .logout { margin-left: auto; background: #c0392b; padding: 5px 12px; border-radius: 4px; color: #fff; }

        /* LAYOUT */
        .wrap { display: flex; min-height: calc(100vh - 50px); }
        aside { width: 200px; background: #fff; border-right: 1px solid #ddd; padding: 16px 0; flex-shrink: 0; }
        aside a { display: block; padding: 9px 16px; color: #333; text-decoration: none; border-left: 3px solid transparent; }
        aside a:hover, aside a.active { background: #eef3f8; border-left-color: #1a3a5c; color: #1a3a5c; }
        aside .section { font-size: 11px; color: #999; text-transform: uppercase; padding: 12px 16px 4px; letter-spacing: 1px; }
        main { flex: 1; padding: 24px; }

        /* COMPONENTS */
        h1 { font-size: 20px; margin-bottom: 4px; }
        .sub { color: #777; margin-bottom: 20px; font-size: 13px; }
        table { width: 100%; border-collapse: collapse; background: #fff; }
        th { text-align: left; padding: 10px; background: #f0f0f0; font-size: 12px; text-transform: uppercase; border-bottom: 2px solid #ddd; }
        td { padding: 10px; border-bottom: 1px solid #eee; }
        tr:hover td { background: #fafafa; }
        .card { background: #fff; border: 1px solid #ddd; border-radius: 6px; padding: 20px; margin-bottom: 16px; }
        .stats { display: flex; gap: 12px; margin-bottom: 20px; }
        .stat { background: #fff; border: 1px solid #ddd; border-radius: 6px; padding: 16px 20px; min-width: 130px; }
        .stat .num { font-size: 28px; font-weight: bold; color: #1a3a5c; }
        .stat .lbl { font-size: 12px; color: #888; margin-top: 2px; }
        .btn { display: inline-block; padding: 7px 14px; border-radius: 4px; border: none; cursor: pointer; font-size: 13px; text-decoration: none; }
        .btn-blue { background: #1a3a5c; color: #fff; }
        .btn-red { background: #c0392b; color: #fff; }
        .btn-green { background: #27ae60; color: #fff; }
        .form-group { margin-bottom: 14px; }
        .form-group label { display: block; font-size: 12px; color: #555; margin-bottom: 4px; font-weight: bold; }
        .form-group input, .form-group select, .form-group textarea { width: 100%; padding: 8px 10px; border: 1px solid #ccc; border-radius: 4px; font-size: 13px; }
        .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
        .alert-success { background: #d4efdf; color: #1e7e34; padding: 10px 14px; border-radius: 4px; margin-bottom: 14px; }
        .alert-error   { background: #fadbd8; color: #c0392b; padding: 10px 14px; border-radius: 4px; margin-bottom: 14px; }
        .badge { padding: 2px 8px; border-radius: 12px; font-size: 11px; font-weight: bold; }
        .badge-g { background: #d4efdf; color: #1e7e34; }
        .badge-r { background: #fadbd8; color: #c0392b; }
        .badge-a { background: #fef9c3; color: #b45309; }
        select.status-select { width: auto; padding: 4px 8px; }
    </style>
</head>
<body>

<nav>
    <span class="brand">🏛 Nalanda Institute</span>
    @if (Context.Session.GetString("Role") != null)
    {
        <span>@Context.Session.GetString("User") (@Context.Session.GetString("Role"))</span>
        <a class="logout" href="@Url.Action("Logout","Home")">Logout</a>
    }
</nav>

<div class="wrap">
    @if (Context.Session.GetString("Role") != null)
    {
        <aside>
            @if (Context.Session.GetString("Role") == "admin")
            {
                <div class="section">Admin</div>
                <a href="@Url.Action("Dashboard","Admin")">Dashboard</a>
                <div class="section">Students</div>
                <a href="@Url.Action("Students","Admin")">All Students</a>
                <a href="@Url.Action("AddStudent","Admin")">Add Student</a>
                <div class="section">Teachers</div>
                <a href="@Url.Action("Teachers","Admin")">All Teachers</a>
                <a href="@Url.Action("AddTeacher","Admin")">Add Teacher</a>
                <div class="section">Reports</div>
                <a href="@Url.Action("Attendance","Admin")">View Attendance</a>
            }
            @if (Context.Session.GetString("Role") == "student")
            {
                <div class="section">Student</div>
                <a href="@Url.Action("Dashboard","Student")">Dashboard</a>
                <a href="@Url.Action("Admission","Student")">Admission Form</a>
                <a href="@Url.Action("Attendance","Student")">My Attendance</a>
                <a href="@Url.Action("Schedule","Student")">Class Schedule</a>
            }
            @if (Context.Session.GetString("Role") == "teacher")
            {
                <div class="section">Teacher</div>
                <a href="@Url.Action("Dashboard","Teacher")">Dashboard</a>
                <a href="@Url.Action("Attendance","Teacher")">Take Attendance</a>
                <a href="@Url.Action("Diary","Teacher")">Daily Diary</a>
                <a href="@Url.Action("Register","Teacher")">My Registration</a>
            }
        </aside>
    }
    <main>
        @RenderBody()
    </main>
</div>

</body>
</html>
