@model List<NalandaSchool.Models.Attendance>
@{ ViewBag.Title = "My Attendance"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<h1>My Attendance</h1>
<p class="sub">Attendance records for your class</p>

<table>
    <thead>
        <tr><th>Date</th><th>Student</th><th>Class</th><th>Status</th></tr>
    </thead>
    <tbody>
        @if (Model.Count == 0)
        {
            <tr><td colspan="4" style="text-align:center;color:#999;">No records yet.</td></tr>
        }
        @foreach (var a in Model)
        {
            <tr>
                <td>@a.Date</td>
                <td>@a.StudentName</td>
                <td>@a.Class</td>
                <td>
                    <span class="badge @(a.Status=="Present"?"badge-g":a.Status=="Absent"?"badge-r":"badge-a")">
                        @a.Status
                    </span>
                </td>
            </tr>
        }
    </tbody>
</table>
